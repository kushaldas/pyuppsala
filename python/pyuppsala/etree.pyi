# ---------------------------------------------------------------------------

class XMLParser:
    def __init__(
        self,
        *,
        huge_tree: bool = False,
        remove_comments: bool = False,
        remove_pis: bool = False,
        strip_cdata: bool = True,
        resolve_entities: bool = True,
        no_network: bool = True,
        recover: bool = False,
        dtd_validation: bool = False,
        load_dtd: bool = False,
        ns_clean: bool = False,
        encoding: Optional[str] = None,
        max_depth: Optional[int] = None,
        max_entity_expansion: Optional[int] = None,
        namespace_aware: Optional[bool] = None,
        forbid_dtd: bool = False,
        forbid_entities: bool = False,
        collect_ids: bool = True,
        compact: bool = True,
        target: Any = None,
        resolvers: Any = None,
    ) -> None: ...

def fromstring(
    text: Union[str, bytes], parser: Optional[XMLParser] = None
) -> _Element: ...
def fromstringlist(
    strings: Iterable[Union[str, bytes]], parser: Optional[XMLParser] = None
) -> _Element: ...

XML = fromstring

def parse(
    source: Any, parser: Optional[XMLParser] = None, base_url: Optional[str] = None
) -> _ElementTree: ...
def tostring(
    element_or_tree: Union[_Element, _ElementTree],
    encoding: Optional[str] = None,
    method: str = "xml",
    xml_declaration: Optional[bool] = None,
    pretty_print: bool = False,
    doctype: Optional[str] = None,
    **kwargs: Any,
) -> Union[str, bytes]: ...
def tounicode(element_or_tree: Union[_Element, _ElementTree], **kwargs: Any) -> str: ...
def dump(elem: Union[_Element, _ElementTree], *, pretty_print: bool = True, **kwargs: Any) -> None: ...
def indent(
    tree: Union[_Element, _ElementTree], space: str = "  ", level: int = 0
) -> None: ...

