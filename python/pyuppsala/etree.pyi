        self,
        path: str,
        default: Any = None,
        namespaces: Optional[dict[str, str]] = None,
    ) -> Any: ...
    def iterfind(
        self, path: str, namespaces: Optional[dict[str, str]] = None
    ) -> Iterator[_Element]: ...
