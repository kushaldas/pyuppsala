"""Type stubs for pyuppsala.etree - the lxml.etree-compatible API."""

from __future__ import annotations

from typing import Any, Callable, Iterable, Iterator, Optional, Union

# ---------------------------------------------------------------------------
# Exceptions
# ---------------------------------------------------------------------------

class LxmlError(Exception): ...

Error = LxmlError

class XMLSyntaxError(LxmlError, SyntaxError): ...

ParseError = XMLSyntaxError

class XPathError(LxmlError): ...
class XPathEvalError(XPathError): ...
class XPathSyntaxError(XPathError, SyntaxError): ...
class DocumentInvalid(LxmlError): ...
class XMLSchemaParseError(LxmlError): ...
class XSLTError(LxmlError): ...
class XSLTParseError(XSLTError): ...
class XSLTApplyError(XSLTError): ...
class XIncludeError(LxmlError): ...

# ---------------------------------------------------------------------------
# Namespaces / QName
# ---------------------------------------------------------------------------

def register_namespace(prefix: str, uri: str) -> None: ...

class QName:
    text: str
    namespace: Optional[str]
    localname: str
    def __init__(
        self, text_or_uri_or_element: Any, tag: Optional[str] = None
    ) -> None: ...
    def __str__(self) -> str: ...
    def __hash__(self) -> int: ...
    def __eq__(self, other: object) -> bool: ...

# ---------------------------------------------------------------------------
# Elements
# ---------------------------------------------------------------------------

_TagName = Union[str, QName]

class _Element:
    tag: Any
    text: Optional[str]
    tail: Optional[str]
    @property
    def attrib(self) -> _Attrib: ...
    @property
    def nsmap(self) -> dict[Optional[str], str]: ...
    @property
    def prefix(self) -> Optional[str]: ...
    @property
    def sourceline(self) -> Optional[int]: ...
    @property
    def base(self) -> Optional[str]: ...
    # attributes
    def get(self, key: _TagName, default: Any = None) -> Any: ...
    def set(self, key: _TagName, value: str) -> None: ...
    def keys(self) -> list[str]: ...
    def values(self) -> list[str]: ...
    def items(self) -> list[tuple[str, str]]: ...
    # sequence protocol
    def __len__(self) -> int: ...
    def __iter__(self) -> Iterator[_Element]: ...
    def __getitem__(self, index: Union[int, slice]) -> Any: ...
    def __setitem__(self, index: int, element: _Element) -> None: ...
    def __delitem__(self, index: Union[int, slice]) -> None: ...
    def __contains__(self, element: object) -> bool: ...
    def index(
        self, child: _Element, start: Optional[int] = None, stop: Optional[int] = None
    ) -> int: ...
    # mutation
    def append(self, element: _Element) -> None: ...
    def extend(self, elements: Iterable[_Element]) -> None: ...
    def insert(self, index: int, element: _Element) -> None: ...
    def remove(self, element: _Element) -> None: ...
    def replace(self, old_element: _Element, new_element: _Element) -> None: ...
    def addnext(self, element: _Element) -> None: ...
    def addprevious(self, element: _Element) -> None: ...
    def makeelement(
        self,
        _tag: _TagName,
        attrib: Optional[dict[str, str]] = None,
        nsmap: Optional[dict[Optional[str], str]] = None,
        **extra: str,
    ) -> _Element: ...
    # navigation
    def getparent(self) -> Optional[_Element]: ...
    def getnext(self) -> Optional[_Element]: ...
    def getprevious(self) -> Optional[_Element]: ...
    def getroottree(self) -> _ElementTree: ...
    def itersiblings(
        self, tag: Optional[str] = None, preceding: bool = False
    ) -> Iterator[_Element]: ...
    def iterancestors(self, tag: Optional[str] = None) -> Iterator[_Element]: ...
    def iterdescendants(self, tag: Optional[str] = None) -> Iterator[_Element]: ...
    # traversal & search
    def iter(self, tag: Optional[str] = None) -> Iterator[_Element]: ...
    def itertext(self) -> Iterator[str]: ...
    def find(
        self, path: str, namespaces: Optional[dict[str, str]] = None
    ) -> Optional[_Element]: ...
    def findall(
        self, path: str, namespaces: Optional[dict[str, str]] = None
    ) -> list[_Element]: ...
    def findtext(
        self,
        path: str,
        default: Any = None,
        namespaces: Optional[dict[str, str]] = None,
    ) -> Any: ...
    def iterfind(
        self, path: str, namespaces: Optional[dict[str, str]] = None
    ) -> Iterator[_Element]: ...
    def xpath(
        self,
        _path: str,
        namespaces: Optional[dict[str, str]] = None,
        smart_strings: bool = True,
        **variables: Any,
    ) -> Any: ...
    def xinclude(self) -> None: ...

class _Attrib:
    def __getitem__(self, key: _TagName) -> str: ...
    def __setitem__(self, key: _TagName, value: str) -> None: ...
    def __delitem__(self, key: _TagName) -> None: ...
    def __contains__(self, key: object) -> bool: ...
    def __len__(self) -> int: ...
    def __iter__(self) -> Iterator[str]: ...
    def get(self, key: _TagName, default: Any = None) -> Any: ...
    def keys(self) -> list[str]: ...
    def values(self) -> list[str]: ...
    def items(self) -> list[tuple[str, str]]: ...
    def update(self, other: Any) -> None: ...

